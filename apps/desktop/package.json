{
  "name": "@triangle/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "node --test test/*.test.ts",
    "probe:mcp": "node scripts/mcp-probe.mjs",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.187",
    "@monaco-editor/react": "4.7.0",
    "chokidar": "4.0.3",
    "dockview-react": "6.6.1",
    "fflate": "0.8.3",
    "lucide-react": "1.18.0",
    "monaco-editor": "0.54.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@triangle/integrations": "workspace:*",
    "@triangle/preview-runtime": "workspace:*",
    "@triangle/robotics": "workspace:*",
    "@triangle/shared": "workspace:*",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "37.6.0",
    "electron-builder": "26.15.3",
    "electron-vite": "4.0.1",
    "motion": "^12.41.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "typescript": "5.9.3",
    "vite": "7.1.12"
  },
  "build": {
    "appId": "ai.triangle.desktop",
    "productName": "Triangle",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out/main/mcp.js",
        "to": "mcp/mcp.js"
      },
      {
        "from": "out/main/chunks",
        "to": "mcp/chunks"
      },
      {
        "from": "build/mcp/package.json",
        "to": "mcp/package.json"
      },
      {
        "from": "../../templates",
        "to": "templates"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
